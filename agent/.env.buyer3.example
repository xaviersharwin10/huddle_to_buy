# ── Buyer 3 env template ─────────────────────────────────────────────────────
# Copy to agent/.env.buyer3 and fill in <PLACEHOLDER> values.
# DO NOT commit .env.buyer3 — it's gitignored.
#
# NOTE: Buyer 3 is used as the "drop-out" in the refund demo.
# To simulate a drop-out, set AUTO_FUND=false before running dropout-replay.sh.
# The dropout-replay.sh script automatically overrides AUTO_FUND=false for buyer3.

# AXL node for this buyer agent (nodeC listens on 9022)
AXL_API=http://127.0.0.1:9022

# Local HTTP port for the agent daemon (used by the Web UI to poll /status)
PORT=3003

# k-anonymity threshold — must match across all buyers in a session
K=3

# Comma-separated 64-hex pubkeys of all peers (nodeA,B,C,S).
# Leave blank to use /topology.tree auto-discovery (less reliable for hub-spoke).
# The start-nodes.sh and boot-demo.sh scripts fill this in automatically.
KNOWN_PEERS=

# ── Gensyn Testnet chain config ──────────────────────────────────────────────
RPC_URL=https://gensyn-testnet.g.alchemy.com/public
CHAIN_ID=685685

# Address of deployed CoalitionFactory
FACTORY_ADDRESS=<COALITION_FACTORY_ADDRESS>

# KeeperHub-authorized EOA address
KEEPER_ADDRESS=<KEEPER_EOA_ADDRESS>

# Seller treasury address
SELLER_ADDRESS=<SELLER_PAYOUT_ADDRESS>

# MockUSDC on Gensyn Testnet (address printed by deploy.ts)
PAY_TOKEN_ADDRESS=<MOCK_USDC_ADDRESS>
PAY_TOKEN_DECIMALS=6

# ── Buyer-specific private key ────────────────────────────────────────────────
PRIVATE_KEY=<BUYER3_PRIVATE_KEY>

# ── Agent behaviour controls ──────────────────────────────────────────────────
# Set AUTO_FUND=false to simulate buyer3 drop-out in the refund demo.
# dropout-replay.sh will override this to false automatically.
AUTO_FUND=true
FUND_DELAY_MS=0

# ── 0G Buyer Profile iNFT (optional) ─────────────────────────────────────────
# ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
# ZEROG_CHAIN_ID=16600
# BUYER_PROFILE_ADDRESS=<BUYER_PROFILE_CONTRACT_ON_0G>
# ZEROG_PRIVATE_KEY=<ZEROG_PRIVATE_KEY>
