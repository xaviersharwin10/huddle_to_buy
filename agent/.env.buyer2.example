# ── Buyer 2 env template ─────────────────────────────────────────────────────
# Copy to agent/.env.buyer2 and fill in <PLACEHOLDER> values.
# DO NOT commit .env.buyer2 — it's gitignored.

# AXL node for this buyer agent (nodeB listens on 9012)
AXL_API=http://127.0.0.1:9012

# Local HTTP port for the agent daemon (used by the Web UI to poll /status)
PORT=3002

# k-anonymity threshold — must match across all buyers in a session
K=3

# Comma-separated 64-hex pubkeys of all peers (nodeA,B,C,S).
# Leave blank to use /topology.tree auto-discovery (less reliable for hub-spoke).
# The start-nodes.sh and boot-demo.sh scripts fill this in automatically.
KNOWN_PEERS=

# ── Gensyn Testnet chain config ──────────────────────────────────────────────
RPC_URL=https://gensyn-testnet.g.alchemy.com/public
CHAIN_ID=685685

# Address of deployed CoalitionFactory (from: cd contracts && pnpm exec hardhat run scripts/deploy.ts --network gensynTestnet)
FACTORY_ADDRESS=<COALITION_FACTORY_ADDRESS>

# KeeperHub-authorized EOA address (the address whose private key runs keeper.ts)
KEEPER_ADDRESS=<KEEPER_EOA_ADDRESS>

# Seller treasury address — receives payment on coalition commit()
SELLER_ADDRESS=<SELLER_PAYOUT_ADDRESS>

# MockUSDC on Gensyn Testnet (address printed by deploy.ts)
PAY_TOKEN_ADDRESS=<MOCK_USDC_ADDRESS>
PAY_TOKEN_DECIMALS=6

# ── Buyer-specific private key ────────────────────────────────────────────────
# Must have Gensyn Testnet ETH (for gas) + MockUSDC (for fund()).
# Get test ETH: from the Gensyn Testnet faucet
# Get MockUSDC: cd contracts && PAY_TOKEN_ADDRESS=<MOCK_USDC> WALLET_ADDRESS=<BUYER> \
#                 pnpm exec hardhat run scripts/mint-mock-usdc.ts --network gensynTestnet
PRIVATE_KEY=<BUYER2_PRIVATE_KEY>

# ── Agent behaviour controls ──────────────────────────────────────────────────
AUTO_FUND=true
FUND_DELAY_MS=0

# ── 0G Buyer Profile iNFT ────────────────────────────────────────────────────
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_CHAIN_ID=16602
BUYER_PROFILE_ADDRESS=0x86583710FB176b5a868262FCc95BFf0DfBeE130C
# ZEROG_PRIVATE_KEY=<key>   # falls back to PRIVATE_KEY if unset

# ── 0G Compute inference ──────────────────────────────────────────────────────
# See .env.buyer1.example for full setup instructions.
ZEROG_COMPUTE_URL=https://compute-network-6.integratenetwork.work
# ZEROG_COMPUTE_API_KEY=app-sk-<your-secret>
# ZEROG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
