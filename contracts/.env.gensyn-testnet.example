# Contracts deployment and keeper execution (Base Sepolia)
GENSYN_TESTNET_RPC=https://gensyn-testnet.g.alchemy.com/public
PRIVATE_KEY=<DEPLOYER_PRIVATE_KEY>

# Optional: explicit keeper key (if different from deployer)
KEEPER_PRIVATE_KEY=<KEEPER_PRIVATE_KEY>

# Coalition address to watch/register after deployment
COALITION_ADDRESS=<DEPLOYED_COALITION_ADDRESS>

# KeeperHub API integration
KEEPERHUB_API_URL=<KEEPERHUB_REGISTRATION_ENDPOINT>
KEEPERHUB_API_KEY=<KEEPERHUB_API_KEY>
DRY_RUN=true
